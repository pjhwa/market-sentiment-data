{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pjhwa/market-sentiment-data/schema.json",
  "title": "MarketSentimentSnapshot",
  "description": "SniperBoard 소셜 심리 파이프라인 데이터 계약 v1.1",
  "type": "object",
  "required": ["generated_at", "market", "symbols", "schema_version"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "이 스냅샷이 생성된 UTC 시각 (ISO8601)"
    },
    "schema_version": {
      "type": "string",
      "enum": ["1.0", "1.1", "1.2", "1.3", "1.4"],
      "description": "1.0: 기본. 1.1: price_context+divergence. 1.2: slot+intraday_shift. 1.3: composite_score. 1.4: top_news 추가."
    },
    "slot": {
      "type": "string",
      "enum": ["pre_open", "post_close"],
      "description": "수집 슬롯. pre_open: 미국 장 개장 전(13:00 UTC). post_close: 미국 장 마감 후(21:00 UTC)."
    },
    "market": {
      "$ref": "#/definitions/MarketSentiment"
    },
    "symbols": {
      "type": "array",
      "items": { "$ref": "#/definitions/SymbolSentiment" },
      "minItems": 0,
      "maxItems": 20
    }
  },
  "definitions": {
    "SentimentEnum": {
      "type": "string",
      "enum": ["very_fearful", "fearful", "neutral", "optimistic", "euphoric"],
      "description": "5단계 감정 범주. sentiment_score 매핑: very_fearful=-2, fearful=-1, neutral=0, optimistic=+1, euphoric=+2"
    },
    "SentimentScore": {
      "type": "integer",
      "enum": [-2, -1, 0, 1, 2],
      "description": "sentiment 범주에서 결정론적으로 파생된 수치. very_fearful=-2, fearful=-1, neutral=0, optimistic=+1, euphoric=+2. Grok이 직접 생성하는 값이 아님."
    },
    "CompositeScore": {
      "type": "number",
      "minimum": -2.0,
      "maximum": 2.0,
      "description": "sentiment_score에 confidence·bot_suspected·mention_volume·divergence·trend·intraday_shift를 결합한 복합 점수. -2.0~+2.0 범위, 소수점 1자리. v1.3에서 추가."
    },
    "TrendEnum": {
      "type": "string",
      "enum": ["cooling", "stable", "heating"],
      "description": "어제 대비 심리 변화 방향"
    },
    "VolumeEnum": {
      "type": "string",
      "enum": ["low", "normal", "elevated", "surging"],
      "description": "소셜 언급량 수준"
    },
    "BotEnum": {
      "type": "string",
      "enum": ["yes", "no", "unclear"],
      "description": "봇·펌프성 글 의심 여부"
    },
    "ConfidenceEnum": {
      "type": "string",
      "enum": ["high", "med", "low"],
      "description": "Grok 자체 신뢰도. low이면 소비측에서 중립 취급"
    },
    "ExtremeFlagEnum": {
      "type": "string",
      "enum": ["none", "extreme_fear", "extreme_greed"],
      "description": "시장 전체 극단 상태 판정. 결합 매트릭스의 공포/도취 극단 판정에 사용"
    },
    "SymbolSentiment": {
      "type": "object",
      "required": [
        "symbol", "as_of", "sentiment", "sentiment_score",
        "trend_vs_yesterday", "mention_volume", "key_reason",
        "bot_suspected", "confidence", "source"
      ],
      "additionalProperties": false,
      "properties": {
        "symbol": {
          "type": "string",
          "description": "종목 티커"
        },
        "as_of": {
          "type": "string",
          "format": "date-time",
          "description": "이 심리의 기준 시각 (ISO8601 UTC)"
        },
        "sentiment": { "$ref": "#/definitions/SentimentEnum" },
        "sentiment_score": { "$ref": "#/definitions/SentimentScore" },
        "trend_vs_yesterday": { "$ref": "#/definitions/TrendEnum" },
        "mention_volume": { "$ref": "#/definitions/VolumeEnum" },
        "key_reason": {
          "type": "string",
          "description": "화제의 핵심 사유 (한 줄)"
        },
        "bot_suspected": { "$ref": "#/definitions/BotEnum" },
        "confidence": { "$ref": "#/definitions/ConfidenceEnum" },
        "source": {
          "type": "string",
          "description": "출처 추적용 문자열"
        },
        "price_context": {
          "$ref": "#/definitions/PriceContext",
          "description": "수집에 쓴 중립 가격 단서 (감사·재현용). v1.1에서 추가. optional."
        },
        "divergence": {
          "$ref": "#/definitions/DivergenceEnum",
          "description": "가격 방향과 심리의 일치/불일치. v1.1에서 추가. optional."
        },
        "intraday_shift": {
          "$ref": "#/definitions/IntradayShiftEnum",
          "description": "post_close 슬롯에서 당일 pre_open 대비 심리 변화. v1.2 추가."
        },
        "composite_score": {
          "$ref": "#/definitions/CompositeScore",
          "description": "모든 수집 신호를 결합한 복합 점수. v1.3 추가. optional."
        },
        "top_news": {
          "oneOf": [
            { "$ref": "#/definitions/TopNews" },
            { "type": "null" }
          ],
          "description": "가장 많이 언급된 뉴스/포스트 1건. 없으면 null. v1.4 추가."
        }
      }
    },
    "PriceContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "volatility": {
          "type": ["string", "null"],
          "enum": ["calm", "normal", "elevated", "extreme", null],
          "description": "당일 변동폭 ÷ ATR14 기반 변동성 크기 (방향 없음)"
        },
        "volume_ratio": {
          "type": ["number", "null"],
          "description": "최근 거래량 ÷ vol_avg20 배수"
        },
        "near_key_level": {
          "type": ["string", "null"],
          "enum": ["none", "near_52w_high", "near_52w_low", null],
          "description": "52주 고점/저점 ±3% 이내 여부 (위치만, 돌파 판정 없음)"
        },
        "abnormal_move": {
          "type": ["boolean", "null"],
          "description": "|당일변동| > 1.5×ATR14 이면 true (방향 무관)"
        }
      }
    },
    "TopNews": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headline": {
          "type": "string",
          "description": "가장 많이 언급된 뉴스/포스트의 원문 제목 또는 캡션 (영문 그대로)"
        },
        "summary": {
          "type": "string",
          "description": "1-2문장 한국어 요약"
        },
        "source": {
          "type": "string",
          "description": "출처 문자열 (예: Bloomberg, @elonmusk, CNBC)"
        }
      }
    },
    "DivergenceEnum": {
      "type": "string",
      "enum": ["aligned", "none", "bullish_divergence", "bearish_divergence"],
      "description": "가격↑심리↓=bearish_divergence, 가격↓심리↑=bullish_divergence, 그 외=aligned/none"
    },
    "IntradayShiftEnum": {
      "type": ["string", "null"],
      "enum": ["cooling", "stable", "heating", null],
      "description": "post_close에서 당일 pre_open 대비 심리 변화. pre_open 슬롯에서는 항상 null."
    },
    "MarketSentiment": {
      "type": "object",
      "required": [
        "as_of", "sentiment", "sentiment_score",
        "trend_vs_yesterday", "extreme_flag", "key_reason", "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "type": "string",
          "format": "date-time",
          "description": "이 심리의 기준 시각 (ISO8601 UTC)"
        },
        "sentiment": { "$ref": "#/definitions/SentimentEnum" },
        "sentiment_score": { "$ref": "#/definitions/SentimentScore" },
        "trend_vs_yesterday": { "$ref": "#/definitions/TrendEnum" },
        "extreme_flag": { "$ref": "#/definitions/ExtremeFlagEnum" },
        "key_reason": {
          "type": "string",
          "description": "시장 전체 화제의 핵심 사유 (한 줄)"
        },
        "confidence": { "$ref": "#/definitions/ConfidenceEnum" },
        "intraday_shift": {
          "$ref": "#/definitions/IntradayShiftEnum",
          "description": "post_close 슬롯에서 당일 pre_open 대비 심리 변화. v1.2 추가."
        },
        "composite_score": {
          "$ref": "#/definitions/CompositeScore",
          "description": "모든 수집 신호를 결합한 복합 점수. v1.3 추가. optional."
        },
        "top_news": {
          "oneOf": [
            { "$ref": "#/definitions/TopNews" },
            { "type": "null" }
          ],
          "description": "가장 많이 언급된 뉴스/포스트 1건. 없으면 null. v1.4 추가."
        }
      }
    }
  }
}
